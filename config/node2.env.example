# Node Identity
NODE_ROLE=backup
NODE_IP=192.168.2.25
PEER_IP=192.168.2.24

# SSH (for HA test remote operations)
SSH_USER=root

# Network
NIC=ens33
VIP=192.168.2.100
VIP_PREFIX=24
KEEPALIVED_PRIORITY=99
KEEPALIVED_AUTH_PASS=123456
KEEPALIVED_VRID=51

# TiDB Ports
PD_CLI_PORT=2379
PD_PEER_PORT=2380
TIKV_PORT=20160
TIKV_STATUS_PORT=20180
TIDB_PORT=4000
TIDB_STATUS_PORT=10080

# Docker Image
TIDBX_IMAGE=tidbx:v7.1.9-0.0
TIDBX_IMAGE_FILE=tidbx-719.tar

# Resource Limits
CPU_LIMIT=2
MEMORY_LIMIT=4G
